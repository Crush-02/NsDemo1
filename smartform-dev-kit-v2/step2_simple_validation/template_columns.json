{
  "meta": {
    "description": "物业导入Excel模板的列定义，用于Luckysheet初始化和校验映射",
    "version": "1.0",
    "totalColumns": 25
  },
  "columns": [
    { "col": 0,  "field": "房产简称",     "type": "text",    "required": true,  "rules": ["房产简称_必填"],                                          "hint": "例：A栋-10层-1001",          "width": 150 },
    { "col": 1,  "field": "楼层",         "type": "integer", "required": true,  "rules": ["楼层_必填"],                                              "hint": "正整数，如：1, 10, 33",      "width": 80  },
    { "col": 2,  "field": "房号",         "type": "text",    "required": true,  "rules": ["房号_必填"],                                              "hint": "例：1001",                    "width": 80  },
    { "col": 3,  "field": "房产类型",     "type": "select",  "required": true,  "rules": ["房产类型_必填"],       "options": ["住宅","车位","商铺","写字楼","其他"], "hint": "选择房产类型", "width": 100 },
    { "col": 4,  "field": "计费面积",     "type": "decimal", "required": false, "rules": ["格式_计费面积"],                                           "hint": "正数，保留4位小数",           "width": 120 },
    { "col": 5,  "field": "售楼日期",     "type": "date",    "required": false, "rules": ["售楼日期_必填","格式_日期"],                                "hint": "YYYY-MM-DD",                  "width": 120 },
    { "col": 6,  "field": "收房日期",     "type": "date",    "required": false, "rules": ["格式_日期"],                                               "hint": "YYYY-MM-DD",                  "width": 120 },
    { "col": 7,  "field": "入住日期",     "type": "date",    "required": false, "rules": ["格式_日期"],                                               "hint": "YYYY-MM-DD",                  "width": 120 },
    { "col": 8,  "field": "业主名称",     "type": "text",    "required": false, "rules": [],                                                          "hint": "填写后触发条件校验",           "width": 120 },
    { "col": 9,  "field": "业主联系电话", "type": "text",    "required": false, "rules": [],                                                          "hint": "填写后触发条件校验",           "width": 130 },
    { "col": 10, "field": "业主证件号码", "type": "text",    "required": false, "rules": ["格式_证件号码"],                                           "hint": "18位身份证号",                "width": 180 },
    { "col": 11, "field": "业主客户类型", "type": "select",  "required": false, "rules": ["业主客户类型_必填"],   "options": ["个人","企业"],              "hint": "有业主信息时必填",            "width": 110 },
    { "col": 12, "field": "业主联系人",   "type": "text",    "required": false, "rules": ["业主客户类型_必填"],                                        "hint": "企业业主时必填",              "width": 120 },
    { "col": 13, "field": "租户名称",     "type": "text",    "required": false, "rules": [],                                                          "hint": "",                            "width": 120 },
    { "col": 14, "field": "租户联系电话", "type": "text",    "required": false, "rules": [],                                                          "hint": "",                            "width": 130 },
    { "col": 15, "field": "租户证件号码", "type": "text",    "required": false, "rules": ["格式_证件号码"],                                           "hint": "18位身份证号",                "width": 180 },
    { "col": 16, "field": "租户证件类型", "type": "select",  "required": false, "rules": ["租户证件类型_必填"],  "options": ["身份证","护照","其他"],     "hint": "有租户信息时相关",            "width": 110 },
    { "col": 17, "field": "租户客户类型", "type": "select",  "required": false, "rules": ["租户客户类型_必填","租户联系人_必填"], "options": ["个人","企业"], "hint": "企业时联系人必填", "width": 110 },
    { "col": 18, "field": "租户联系人",   "type": "text",    "required": false, "rules": ["租户联系人_必填"],                                          "hint": "企业租户时必填",              "width": 120 },
    { "col": 19, "field": "出租开始日期", "type": "date",    "required": false, "rules": ["格式_日期","出租开始日期_必填"],                              "hint": "YYYY-MM-DD",                  "width": 130 },
    { "col": 20, "field": "出租结束日期", "type": "date",    "required": false, "rules": ["格式_日期"],                                               "hint": "YYYY-MM-DD",                  "width": 130 },
    { "col": 21, "field": "备注",         "type": "text",    "required": false, "rules": [],                                                          "hint": "",                            "width": 200 },
    { "col": 22, "field": "项目编号",     "type": "text",    "required": false, "rules": [],                                                          "hint": "",                            "width": 100 },
    { "col": 23, "field": "栋座",         "type": "text",    "required": false, "rules": [],                                                          "hint": "",                            "width": 80  },
    { "col": 24, "field": "单元",         "type": "text",    "required": false, "rules": [],                                                          "hint": "",                            "width": 80  }
  ],
  "conditionTriggers": {
    "有业主信息": {
      "detectFields": [8, 9, 10],
      "detectFieldNames": ["业主名称", "业主联系电话", "业主证件号码"],
      "logic": "OR",
      "triggerRules": ["售楼日期_必填", "业主客户类型_必填"],
      "description": "任一业主字段有值即触发"
    },
    "有租户信息": {
      "detectFields": [13, 14, 15, 19],
      "detectFieldNames": ["租户名称", "租户联系电话", "租户证件号码", "出租开始日期"],
      "logic": "OR",
      "triggerRules": ["租户证件类型_必填", "出租开始日期_必填"],
      "description": "任一租户字段有值即触发"
    },
    "企业客户": {
      "detectFields": [11, 17],
      "detectFieldNames": ["业主客户类型", "租户客户类型"],
      "detectValue": "企业",
      "triggerRules": ["业主客户类型_必填", "租户联系人_必填"],
      "description": "客户类型为企业时触发"
    },
    "收房日期有值": {
      "detectFields": [6],
      "detectFieldNames": ["收房日期"],
      "triggerRules": ["售楼日期_必填"],
      "description": "收房日期有值时触发"
    },
    "入住日期有值": {
      "detectFields": [7],
      "detectFieldNames": ["入住日期"],
      "triggerRules": ["售楼日期_必填"],
      "description": "入住日期有值时触发"
    },
    "证件类型有值": {
      "detectFields": [16],
      "detectFieldNames": ["租户证件类型"],
      "triggerRules": ["租户证件类型_必填"],
      "description": "租户证件类型有值时触发"
    }
  }
}
